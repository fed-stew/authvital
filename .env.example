# =============================================================================
# AuthVital - Environment Configuration
# =============================================================================
#
# Copy this file to .env and update values:
#   cp .env.example .env
#
# =============================================================================

# =============================================================================
# DATABASE (Required)
# =============================================================================
# Option 1: Full DATABASE_URL
DATABASE_URL=postgresql://authvital:localdev123@localhost:5432/authvital

# Option 2: Individual components (docker-compose builds URL from these)
# DB_HOST=localhost
# DB_USERNAME=authvital
# DB_PASSWORD=localdev123
# DB_DATABASE=authvital

# =============================================================================
# APPLICATION (Required)
# =============================================================================
# Base URL - used for OAuth issuer, redirects, email links, CORS
# Must include protocol (http/https) and NO trailing slash
#
# For direct local development (npm run dev): http://localhost:8000
# For Docker Compose: http://localhost:8080
BASE_URL=http://localhost:8000

# Server port
PORT=8000

# Environment (development | production)
NODE_ENV=development

# =============================================================================
# SECURITY (Required)
# =============================================================================
# Master Secret - 32 bytes as hex (64 characters)
# Root-of-trust key used to:
#   - Encrypt JWT signing keys (Ed25519) at rest in the database
#   - Derive HMAC keys for cookies, CSRF tokens, and auth codes
#   - Encrypt sensitive data (e.g., OAuth client secrets) in the database
#
# JWTs are NOT signed directly with this key. Instead, AuthVital uses
# automatically rotating Ed25519 key pairs (see KEY_ROTATION_INTERVAL_SECONDS).
# This master secret protects those rotating keys at rest.
#
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ⚠️  CHANGE THIS IN PRODUCTION!
# ⚠️  If you change this, all existing sessions/tokens become invalid
#      (the stored signing keys can no longer be decrypted)
MASTER_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Cookie secure flag - set to 'false' for local HTTP development
# Default: true in production (NODE_ENV=production), false otherwise
COOKIE_SECURE=false

# =============================================================================
# CORS (Optional)
# =============================================================================
# Additional CORS origins (comma-separated)
# Supports wildcards: https://*.example.com
# BASE_URL is automatically included
#
# For Docker Compose local development, include:
# CORS_ORIGINS=http://localhost:8080
#
# For production with multiple subdomains:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# =============================================================================
# EMAIL - SendGrid (Optional)
# =============================================================================
# If not set, emails are logged to console (fine for local dev)
#
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com
# SENDGRID_FROM_NAME=AuthVital

# =============================================================================
# SUPER ADMIN BOOTSTRAP (Optional)
# =============================================================================
# Email for the initial super admin account (created on first run)
# A password reset email is sent to this address
SUPER_ADMIN_EMAIL=admin@localhost

# Alternative: Set a default password (NOT recommended for production)
# DEFAULT_SUPER_ADMIN_EMAIL=admin@localhost
# DEFAULT_SUPER_ADMIN_PASSWORD=changeme123

# =============================================================================
# KEY ROTATION (Optional)
# =============================================================================
# How often to rotate JWT signing keys (in seconds)
# Default: 604800 (7 days)
# KEY_ROTATION_INTERVAL_SECONDS=604800

# =============================================================================
# DOCKER COMPOSE LOCAL DEVELOPMENT (Optional)
# =============================================================================
# When running with docker-compose, these are the recommended settings:
#
#   BASE_URL=http://localhost:8080
#   COOKIE_SECURE=false
#   CORS_ORIGINS=http://localhost:8080
#
# The docker-compose.yml already sets appropriate defaults, but you can
# override them here if needed.

# =============================================================================
# GCP PUB/SUB (Optional)
# =============================================================================
# GCP project ID for Pub/Sub publishing.
# Uses Application Default Credentials (ADC) — no explicit key needed if
# running with the same service account that deploys AuthVital.
#
# Pub/Sub configuration (topic, events, enable/disable) is managed via
# the Super Admin dashboard at /admin → Pub/Sub.
#
# PUBSUB_PROJECT_ID=your-gcp-project-id
#
# For local development with the Pub/Sub emulator:
# PUBSUB_EMULATOR_HOST=localhost:8085
