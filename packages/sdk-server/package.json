{
  "name": "@authvital/server",
  "version": "0.1.0",
  "description": "AuthVital Server SDK - BFF/SSR adapter for Next.js, Express, and other server environments",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.mjs",
      "require": "./dist/session/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.mjs",
      "require": "./dist/middleware/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.mjs",
      "require": "./dist/crypto/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@authvital/core": "^1.0.0",
    "@authvital/shared": "*"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "cookie": "^0.6.0",
    "eslint": "^8.53.0",
    "express": "^4.18.0",
    "next": "^14.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "auth",
    "oauth",
    "authentication",
    "authvital",
    "identity",
    "server",
    "ssr",
    "bff",
    "nextjs",
    "express",
    "middleware",
    "session",
    "cookies"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/intersparkio/authvital",
    "directory": "packages/sdk-server"
  },
  "homepage": "https://github.com/intersparkio/authvital#readme",
  "bugs": {
    "url": "https://github.com/intersparkio/authvital/issues"
  }
}
