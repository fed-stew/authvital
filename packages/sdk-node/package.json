{
  "name": "@authvital/node",
  "version": "0.1.0",
  "description": "AuthVital Node.js SDK - Server SDK, API client, JWT validator, webhooks, and identity sync",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {},
  "dependencies": {},
  "devDependencies": {
    "@authvital/shared": "file:../shared",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "node",
    "auth",
    "oauth",
    "authentication",
    "authvital",
    "identity",
    "idp",
    "multi-tenant",
    "saas",
    "jwt",
    "webhooks",
    "sync"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/intersparkio/authvital",
    "directory": "packages/sdk-node"
  },
  "homepage": "https://github.com/intersparkio/authvital#readme",
  "bugs": {
    "url": "https://github.com/intersparkio/authvital/issues"
  }
}
